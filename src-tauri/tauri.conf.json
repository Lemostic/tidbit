{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tidbit",
  "version": "0.1.1",
  "identifier": "tidbit",
  "build": { "beforeDevCommand": "pnpm dev", "beforeBuildCommand": "pnpm build", "frontendDist": "../dist", "devUrl": "http://localhost:1420" },
  "app": {
    "windows": [
      { "label": "main", "title": "tidbit", "url": "index.html", "width": 500, "height": 780, "minWidth": 380, "minHeight": 520, "center": true, "decorations": false, "resizable": true, "transparent": true, "shadow": false }
    ],
    "security": { "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'" }
  },
  "bundle": { "active": true, "targets": ["nsis", "msi"], "icon": ["icons/icon.ico", "icons/icon.png"] }
}
